# Copy to repo root: cp .env.example .env  (Vite loads this file via envDir; seed script too)
#
# --- API server (@workspace/api-server) ---
# Load env when starting the API, e.g. from repo root:
#   set -a && source .env && set +a && pnpm dev:api
# PostgreSQL connection string (matches docker-compose below if using local Docker)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/english_practice

# OpenAI: use official API (outside Replit) — same variable names the code expects
AI_INTEGRATIONS_OPENAI_API_KEY=sk-your-key-here
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# Port for Express API
PORT=3000

# Optional
# LOG_LEVEL=info
# NODE_ENV=development

# --- Vite dev (@workspace/english-practice) ---
# Frontend dev server port
# VITE_PORT=5173

# Base path for the SPA (usually "/" locally)
BASE_PATH=/

# Proxy /api from Vite to the API server so the browser can use same-origin /api/... URLs
# Leave unset in production builds behind a reverse proxy that routes /api to the backend
API_PROXY_TARGET=http://127.0.0.1:3000
