{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "node -e \"if(process.env.npm_execpath.indexOf('pnpm') === -1) {console.error('Use pnpm instead'); process.exit(1);}\"",
    "dev": "dotenv -e .env -- pnpm -r --parallel --filter @workspace/api-server --filter @workspace/english-practice run dev",
    "dev:win": "pnpm -r --parallel --filter @workspace/api-server --filter @workspace/english-practice run dev",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "db:push": "pnpm --filter @workspace/db run push",
    "db:seed": "pnpm --filter @workspace/scripts run seed-scenarios",
    "dev:api": "pnpm --filter @workspace/api-server run dev",
    "dev:web": "pnpm --filter @workspace/english-practice run dev"
  },
  "private": true,
  "devDependencies": {
    "@types/nanoid": "^3.0.0",
    "dotenv-cli": "^11.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "dependencies": {
    "nanoid": "^5.1.7",
    "zustand": "^5.0.12"
  }
}
